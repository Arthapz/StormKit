set(CMAKE_IMPORT_FILE_VERSION 1)

if(${VCPKG_TOOLCHAIN})
    get_filename_component(PACKAGE_PREFIX_DIR "${CMAKE_CURRENT_LIST_DIR}/../.." ABSOLUTE)
else()
    get_filename_component(PACKAGE_PREFIX_DIR "${CMAKE_CURRENT_LIST_DIR}/../../.." ABSOLUTE)
endif()

set(LIBRARY_NAME @PACKAGE_LIBRARY_NAME@)
set(LIBRARY_PATH @PACKAGE_LIBRARY_PATH@)
set(INCLUDE_PATH @PACKAGE_INCLUDE_PATH@)

string(TOLOWER ${LIBRARY_NAME} LOWER_LIBRARY_NAME)

set(DEPENDENCIES @PACKAGE_DEPENDENCIES@)

set(DEPENDENCIES_TARGETS)
foreach(dependency ${DEPENDENCIES})
    find_package(${dependency} REQUIRED)
endforeach()

if(EXISTS "${LIBRARY_PATH}/${CMAKE_SHARED_LIBRARY_PREFIX}StormKit-${LOWER_LIBRARY_NAME}${CMAKE_LINK_LIBRARY_SUFFIX}")
    add_library("${LIBRARY_NAME}-shared-release" SHARED IMPORTED GLOBAL)
    set_target_properties("${LIBRARY_NAME}-shared-release" PROPERTIES IMPORTED_LOCATION "${LIBRARY_PATH}/${CMAKE_SHARED_LIBRARY_PREFIX}StormKit-${LOWER_LIBRARY_NAME}${CMAKE_LINK_LIBRARY_SUFFIX}")
endif()

if(EXISTS "${LIBRARY_PATH}/${CMAKE_SHARED_LIBRARY_PREFIX}StormKit-${LOWER_LIBRARY_NAME}-debug${CMAKE_LINK_LIBRARY_SUFFIX}")
    add_library("${LIBRARY_NAME}-shared-debug" SHARED IMPORTED GLOBAL)
    set_target_properties("${LIBRARY_NAME}-shared-debug" PROPERTIES IMPORTED_LOCATION "${LIBRARY_PATH}/${CMAKE_SHARED_LIBRARY_PREFIX}StormKit-${LOWER_LIBRARY_NAME}-debug${CMAKE_LINK_LIBRARY_SUFFIX}")
endif()

if(EXISTS "${LIBRARY_PATH}/${CMAKE_STATIC_LIBRARY_PREFIX}StormKit-${LOWER_LIBRARY_NAME}-static${CMAKE_STATIC_LIBRARY_SUFFIX}")
    add_library("${LIBRARY_NAME}-static-release" STATIC IMPORTED GLOBAL)
    set_target_properties("${LIBRARY_NAME}-static-release" PROPERTIES IMPORTED_LOCATION "${LIBRARY_PATH}/${CMAKE_STATIC_LIBRARY_PREFIX}StormKit-${LOWER_LIBRARY_NAME}-static${CMAKE_STATIC_LIBRARY_SUFFIX}")
endif()

if(EXISTS "${LIBRARY_PATH}/${CMAKE_STATIC_LIBRARY_PREFIX}StormKit-${LOWER_LIBRARY_NAME}-static-debug${CMAKE_STATIC_LIBRARY_SUFFIX}")
    add_library("${LIBRARY_NAME}-static-debug" STATIC IMPORTED GLOBAL)
    set_target_properties("${LIBRARY_NAME}-static-debug" PROPERTIES IMPORTED_LOCATION "${LIBRARY_PATH}/${CMAKE_STATIC_LIBRARY_PREFIX}StormKit-${LOWER_LIBRARY_NAME}-static-debug${CMAKE_STATIC_LIBRARY_SUFFIX}")
endif()

set(BUILD_TYPE "release")
set(BUILD_VARIANT "shared")

if(STORMKIT_USE_STATIC)
    set(BUILD_VARIANT "static")
endif()

if(CMAKE_BUILD_TYPE STREQUAL "Debug")
    if(STORMKIT_USE_STATIC AND TARGET ${LIBRARY_NAME}-static-debug)
        set(BUILD_TYPE "debug")
    else()
        if(TARGET ${LIBRARY_NAME}-shared-debug)
            set(BUILD_TYPE "debug")
        endif()
    endif()
endif()

set(TARGET_NAME "${LIBRARY_NAME}-${BUILD_VARIANT}-${BUILD_TYPE}")
set_target_properties(${TARGET_NAME} PROPERTIES
    INTERFACE_COMPILE_FEATURES "cxx_std_17"
    INTERFACE_INCLUDE_DIRECTORIES ${INCLUDE_PATH}
    INTERFACE_LINK_LIBRARIES @PACKAGE_STORMKIT_DEPENDENCIES@
)

if(NOT TARGET ${TARGET_NAME})
    set(StormKit_${LIBRARY_NAME}_FOUND FALSE)
else()
    add_library(StormKit::${LIBRARY_NAME} ALIAS ${TARGET_NAME})
    set(StormKit_${LIBRARY_NAME}_FOUND TRUE)
endif()
