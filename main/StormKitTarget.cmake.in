set(CMAKE_IMPORT_FILE_VERSION 1)

get_filename_component(PACKAGE_PREFIX_DIR "${CMAKE_CURRENT_LIST_DIR}/../../.." ABSOLUTE)

set(LIBRARY_NAME @PACKAGE_LIBRARY_NAME@)
set(LIBRARY_PATH @PACKAGE_LIBRARY_PATH@)
set(INCLUDE_PATH @PACKAGE_INCLUDE_PATH@)

string(TOLOWER ${LIBRARY_NAME} LOWER_LIBRARY_NAME)

set(DEPENDENCIES @PACKAGE_DEPENDENCIES@)

set(DEPENDENCIES_TARGETS)
foreach(dependency ${DEPENDENCIES})
    find_package(${dependency} REQUIRED)
endforeach()

if(EXISTS "${LIBRARY_PATH}/libStormKit-main${CMAKE_STATIC_LIBRARY_SUFFIX}")
    add_library("${LIBRARY_NAME}-release" STATIC IMPORTED GLOBAL)
    set_target_properties("${LIBRARY_NAME}-shared-release" PROPERTIES IMPORTED_LOCATION "${LIBRARY_PATH}/libStormKit-main${CMAKE_STATIC_LIBRARY_SUFFIX}")
endif()

if(EXISTS "${LIBRARY_PATH}/libStormKit-main-debug${CMAKE_STATIC_LIBRARY_SUFFIX}")
    add_library("${LIBRARY_NAME}-debug" STATIC IMPORTED GLOBAL)
    set_target_properties("${LIBRARY_NAME}-debug" PROPERTIES IMPORTED_LOCATION "${LIBRARY_PATH}/libStormKit-main-debug${CMAKE_STATIC_LIBRARY_SUFFIX}")
endif()

set(BUILD_TYPE "release")

if(CMAKE_BUILD_TYPE STREQUAL "Debug")
    if(TARGET ${LIBRARY_NAME}-debug)
        set(BUILD_TYPE "debug")
    endif()
endif()

set(TARGET_NAME "${LIBRARY_NAME}-${BUILD_TYPE}")
target_link_libraries(${TARGET_NAME} INTERFACE @PACKAGE_STORMKIT_DEPENDENCIES@)
target_include_directories(${TARGET_NAME} INTERFACE ${INCLUDE_PATH})

if(NOT TARGET ${TARGET_NAME})
    set(StormKit_${LIBRARY_NAME}_FOUND FALSE)
else()
    add_library(StormKit::${LIBRARY_NAME} ALIAS ${TARGET_NAME})
    set(StormKit_${LIBRARY_NAME}_FOUND TRUE)
endif()
