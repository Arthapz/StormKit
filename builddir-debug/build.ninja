# Test rules

build meson-test: CUSTOM_COMMAND all PHONY
 COMMAND = /usr/local/Cellar/meson/0.54.1_2/libexec/bin/meson test --no-rebuild --print-errorlogs
 DESC = Running$ all$ tests.
 pool = console

build test: phony meson-test

build meson-benchmark: CUSTOM_COMMAND all PHONY
 COMMAND = /usr/local/Cellar/meson/0.54.1_2/libexec/bin/meson test --benchmark --logbase benchmarklog --num-processes=1 --no-rebuild
 DESC = Running$ benchmark$ suite.
 pool = console

build benchmark: phony meson-benchmark

# Install rules

build meson-install: CUSTOM_COMMAND PHONY | all
 DESC = Installing$ files.
 COMMAND = /usr/local/Cellar/meson/0.54.1_2/libexec/bin/meson install --no-rebuild
 pool = console

build install: phony meson-install

build meson-dist: CUSTOM_COMMAND PHONY
 DESC = Creating$ source$ packages
 COMMAND = /usr/local/Cellar/meson/0.54.1_2/libexec/bin/meson dist
 pool = console

build dist: phony meson-dist

# Suffix

build meson-clang-format: CUSTOM_COMMAND PHONY
 COMMAND = /usr/local/Cellar/meson/0.54.1_2/libexec/bin/meson --internal clangformat /Users/arthurlaurent/Developpement/repos/stormkit /Users/arthurlaurent/Developpement/repos/stormkit/builddir-debug
 pool = console

build clang-format: phony meson-clang-format

build meson-ctags: CUSTOM_COMMAND PHONY
 COMMAND = /usr/local/Cellar/meson/0.54.1_2/libexec/bin/meson --internal tags ctags /Users/arthurlaurent/Developpement/repos/stormkit
 pool = console

build ctags: phony meson-ctags

build meson-uninstall: CUSTOM_COMMAND PHONY
 COMMAND = /usr/local/Cellar/meson/0.54.1_2/libexec/bin/meson --internal uninstall
 pool = console

build uninstall: phony meson-uninstall

build all: phony core/libStormKit-core-static-debug.a entities/libStormKit-entities-static-debug.a log/libStormKit-log-static-debug.a module/libStormKit-module-static-debug.a main/libStormKit-main-debug.a window/libStormKit-window-static-debug.a window/plugins/macOS/libStormKit-window-macOS-debug.dylib window/samples/simple_window/stormkit_SimpleWindow image/libStormKit-image-static-debug.a render/libStormKit-render-static-debug.a render/samples/Triangle/stormkit_Triangle render/samples/UniformBuffer/stormkit_UniformBuffer render/samples/Texture/stormkit_Texture engine/libStormKit-engine-static-debug.a engine/samples/ModelLoading/stormkit_ModelLoading

build clean: phony meson-clean

build meson-clean: CUSTOM_COMMAND PHONY
 COMMAND = /usr/local/bin/ninja -t clean
 description = Cleaning

build build.ninja: REGENERATE_BUILD ../meson.build ../meson_options.txt /usr/bin/git ../core/meson.build ../core/include/storm/core/Configure.hpp.in ../entities/meson.build ../log/meson.build ../module/meson.build ../main/meson.build ../window/meson.build ../window/plugins/meson.build ../window/plugins/macOS/meson.build ../window/samples/meson.build ../window/samples/simple_window/meson.build ../image/meson.build ../render/meson.build ../render/samples/meson.build ../render/samples/Triangle/meson.build ../render/samples/UniformBuffer/meson.build ../render/samples/Texture/meson.build ../engine/meson.build ../engine/samples/meson.build ../engine/samples/ModelLoading/meson.build ../StormKitConfig.cmake.in ../StormKitStaticTargets.cmake.in ../StormKitStaticTargets-debug.cmake.in ../StormKitStaticTargets-release.cmake.in ../StormKitSharedTargets.cmake.in ../StormKitSharedTargets-debug.cmake.in ../StormKitSharedTargets-release.cmake.in meson-private/coredata.dat
 pool = console

build reconfigure: REGENERATE_BUILD PHONY
 pool = console

